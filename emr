<script>
let K=localStorage.getItem('gk')||'',gscD=[];
const GROQ='https://api.groq.com/openai/v1/chat/completions',MDL='llama-3.3-70b-versatile';
const SYS=`You are a world-class SEO expert, senior content strategist, and Google Helpful Content specialist with 15+ years experience. You provide SURGICAL, page-specific, actionable SEO recommendations. When analyzing pages, ALWAYS specify the EXACT LOCATION — which heading number, which paragraph, what section — where to make changes. Write ready-to-paste content. Never generic advice. Be specific, strategic, data-driven. Use markdown formatting with tables.`;

document.addEventListener('DOMContentLoaded',()=>{updS();if(!K)setTimeout(openM,800);initCi();});
document.getElementById('modal').addEventListener('click',e=>{if(e.target===document.getElementById('modal'))closeM();});
function updS(){const d=document.getElementById('api-dot'),t=document.getElementById('api-txt');if(K){d.classList.add('live');t.textContent='API Ready';}else{d.classList.remove('live');t.textContent='Set API Key';}}
function openM(){document.getElementById('key-inp').value=K;document.getElementById('modal').classList.add('on');}
function closeM(){document.getElementById('modal').classList.remove('on');}
function saveKey(){const v=document.getElementById('key-inp').value.trim();if(!v)return alert('Key daalo!');K=v;localStorage.setItem('gk',v);updS();closeM();}
function goP(n,b){document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));document.querySelectorAll('.sb-btn').forEach(x=>x.classList.remove('on'));document.getElementById('p-'+n).classList.add('on');b.classList.add('on');}
function initCi(){document.querySelectorAll('.mod-item input').forEach(i=>i.addEventListener('change',function(){this.closest('.mod-item').classList.toggle('on',this.checked);}));}
function selA(id){document.querySelectorAll('#'+id+' input').forEach(c=>{c.checked=true;c.closest('.mod-item').classList.add('on');});}
function desA(id){document.querySelectorAll('#'+id+' input').forEach(c=>{c.checked=false;c.closest('.mod-item').classList.remove('on');});}
function gChk(id){return[...document.querySelectorAll('#'+id+' input:checked')].map(c=>c.value);}
function addC(id,mx){const l=document.getElementById(id);if(l.querySelectorAll('.crow').length>=mx)return alert('Max '+mx+'!');const n=l.querySelectorAll('.crow').length+1;const d=document.createElement('div');d.className='crow';d.innerHTML=`<div class="cnum">${n}</div><input type="url" placeholder="https://competitor${n}.com"><textarea placeholder="Content (optional)" rows="2"></textarea><button class="rm" onclick="this.closest('.crow').remove()">✕</button>`;l.appendChild(d);}
function gComps(id){return[...document.querySelectorAll('#'+id+' .crow')].map(r=>({url:r.querySelector('input[type=url]')?.value?.trim()||'',content:r.querySelector('textarea')?.value?.trim()||''})).filter(c=>c.url||c.content);}
function addBulk(){const l=document.getElementById('bulk-list');if(l.children.length>=5)return alert('Max 5!');const n=l.children.length+1;const d=document.createElement('div');d.style.cssText='display:flex;gap:8px;align-items:center';d.innerHTML=`<div style="width:26px;height:26px;background:var(--b1);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.68rem;color:var(--t3);flex-shrink:0">${n}</div><input type="url" placeholder="https://yoursite.com/page-${n}" style="flex:1">`;l.appendChild(d);}
function clrBulk(){document.getElementById('bulk-list').innerHTML='<div style="display:flex;gap:8px;align-items:center"><div style="width:26px;height:26px;background:var(--b1);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.68rem;color:var(--t3);flex-shrink:0">1</div><input type="url" placeholder="https://yoursite.com/page-1"></div>';}
function gBulk(){return[...document.querySelectorAll('#bulk-list input')].map(i=>i.value.trim()).filter(Boolean);}
function hDrop(e,p){e.preventDefault();const f=e.dataTransfer.files[0];if(f)procCsv(f,p);document.getElementById(p+'-dz')?.classList.remove('drag');}
function lCsv(inp,p){procCsv(inp.files[0],p);}
function procCsv(file,p){const r=new FileReader();r.onload=e=>{const rows=e.target.result.split('\n').map(row=>row.split(',').map(c=>c.trim().replace(/^"|"$/g,'')));gscD=rows.slice(1).filter(r=>r.length>1&&r[0]).map(r=>({query:r[0]||'',clicks:parseInt(r[1])||0,impressions:parseInt(r[2])||0,ctr:parseFloat(r[3])||0,position:parseFloat(r[4])||0})).filter(r=>r.query);if(p==='gsc'){document.getElementById('gsc-cnt').textContent=gscD.length;const tb=document.querySelector('#gsc-tbl tbody');tb.innerHTML=gscD.slice(0,20).map((r,i)=>`<tr><td>${i+1}</td><td>${r.query}</td><td>${r.clicks}</td><td>${r.impressions}</td><td>${(r.ctr*100).toFixed(1)}%</td><td><span class="pb ${r.position<=10?'pt':r.position<=20?'pm':'pl'}">${r.position.toFixed(1)}</span></td></tr>`).join('');document.getElementById('gsc-prev').classList.remove('hidden');}if(p==='k'){document.getElementById('k-info').innerHTML=`<div class="alert al-i">✅ ${gscD.length} GSC queries loaded</div>`;document.getElementById('k-info').classList.remove('hidden');}};r.readAsText(file);}
async function callAPI(prompt){if(!K){openM();throw new Error('API key set karo');}const res=await fetch(GROQ,{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${K}`},body:JSON.stringify({model:MDL,max_tokens:4096,messages:[{role:'system',content:SYS},{role:'user',content:prompt}]})});if(!res.ok){const e=await res.json();throw new Error(e.error?.message||'API Error');}const d=await res.json();return d.choices[0].message.content;}
const tmrs={};
function showL(p){document.getElementById(p+'-loader').classList.add('on');const r=document.getElementById(p+'-result');if(r)r.classList.remove('on');animP(p);}
function hideL(p){document.getElementById(p+'-loader').classList.remove('on');clearInterval(tmrs[p]);}
function showR(p){const r=document.getElementById(p+'-result');if(r){r.classList.add('on');r.scrollIntoView({behavior:'smooth',block:'start'});}}
function resetR(p){const r=document.getElementById(p+'-result');if(r)r.classList.remove('on');const o=document.getElementById(p+'-out');if(o)o.innerHTML='';}
function animP(p){const fill=document.getElementById(p+'-prog');if(!fill)return;const steps=document.querySelectorAll(`#${p}-loader .lstep`);let cur=0;tmrs[p]=setInterval(()=>{if(cur<93){cur+=Math.random()*6+2;if(cur>93)cur=93;fill.style.width=cur+'%';}if(steps.length){const si=Math.floor((cur/100)*steps.length);steps.forEach((s,i)=>{s.classList.toggle('on',i===si);s.classList.toggle('done',i<si);});}},700);}
function doneP(p){clearInterval(tmrs[p]);const f=document.getElementById(p+'-prog');if(f)f.style.width='100%';document.querySelectorAll(`#${p}-loader .lstep`).forEach(s=>{s.classList.remove('on');s.classList.add('done');});}
function md2h(md){return md.replace(/^#### (.*$)/gim,'<h4>$1</h4>').replace(/^### (.*$)/gim,'<h3>$1</h3>').replace(/^## (.*$)/gim,'<h2>$1</h2>').replace(/^# (.*$)/gim,'<h1>$1</h1>').replace(/\*\*\*(.*?)\*\*\*/g,'<strong><em>$1</em></strong>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\*(.*?)\*/g,'<em>$1</em>').replace(/```(\w+)?\n([\s\S]*?)```/g,'<pre><code>$2</code></pre>').replace(/`([^`]+)`/g,'<code>$1</code>').replace(/^> (.*$)/gim,'<blockquote><p>$1</p></blockquote>').replace(/^---$/gim,'<hr>').replace(/^\d+\. (.*)$/gim,'<li>$1</li>').replace(/^[-*] (.*)$/gim,'<li>$1</li>').replace(/\n\n/g,'</p><p>').replace(/^(?!<[hHuUpPbBlLoO><\/])(.*[^\n])$/gim,m=>m.startsWith('<')?m:`<p>${m}</p>`).replace(/<p><\/p>/g,'').replace(/<p>(<[hH])/g,'$1').replace(/(<\/[hH][1-6]>)<\/p>/g,'$1');}
function cpAll(id){const t=document.getElementById(id)?.innerText||'';navigator.clipboard.writeText(t).then(()=>{const b=event.target;b.textContent='✓ Copied!';setTimeout(()=>b.textContent='📋 Copy',2000);});}
function dlMd(id,fn){const t=document.getElementById(id)?.innerText||'';const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([t],{type:'text/markdown'}));a.download=fn;a.click();}

async function runGap(){
  const url=document.getElementById('g-url').value.trim(),content=document.getElementById('g-content').value.trim();
  if(!content&&!url)return alert('Page content paste karo!');if(!K)return openM();
  const kw=document.getElementById('g-kw').value.trim(),lang=document.getElementById('g-lang').value,mods=gChk('g-mods'),comps=gComps('g-comps');
  showL('g');
  const ct=comps.map((c,i)=>`Competitor ${i+1}: ${c.url||'N/A'}\n${c.content?'Content: '+c.content.substring(0,600):''}`).join('\n\n');
  const prompt=`SURGICAL SEO Gap Analysis. Every fix must have EXACT LOCATION on page.

MY PAGE: URL: ${url||'N/A'} | Keyword: "${kw||'N/A'}"
Content: ${content?content.substring(0,2000):'Not provided'}
COMPETITORS: ${ct||'Simulate top 4 for keyword: '+kw}
MODULES: ${mods.join(', ')} | LANGUAGE: ${lang}

